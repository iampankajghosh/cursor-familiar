{
  "name": "cursor-pet",
  "version": "1.0.0",
  "description": "Animated pixel pets that follow your cursor.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "public"
  ],
  "sideEffects": false,
  "keywords": [
    "react",
    "cursor",
    "cursor-pet",
    "pixel-art",
    "sprite",
    "sprite-sheet",
    "animation",
    "cursor-follower",
    "retro",
    "game-ui",
    "pixel",
    "react-component"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iampankajghosh/cursor-pet.git"
  },
  "homepage": "https://github.com/iampankajghosh/cursor-pet#readme",
  "bugs": {
    "url": "https://github.com/iampankajghosh/cursor-pet/issues"
  },
  "author": "Pankaj Ghosh",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "bunchee",
    "dev": "bunchee --watch",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "bunchee": "^6.5.4",
    "typescript": "^5.9.3"
  }
}
