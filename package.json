{
  "name": "cursor-familiar-workspace",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "build:package": "pnpm --filter cursor-familiar build",
    "pack:package": "pnpm --dir packages/cursor-familiar pack",
    "release:check": "pnpm build:package && pnpm pack:package && tar -tf packages/cursor-familiar/cursor-familiar-0.0.1.tgz",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "clean": "pnpm -r exec rm -rf dist node_modules .turbo",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "bunchee": "^6.10.0",
    "typescript": "^5.8.3"
  }
}
